#!/usr/bin/env sh

set -e

# The Dockerfile declares ARG ROOT=/app but does not export it as ENV,
# so provide a safe fallback for runtime scripts that reference it.
ROOT="${ROOT:-/app}"

container_mode=${CONTAINER_MODE:-"http"}

check_supervisor_program() {
    program_name="$1"
    status_output="$(supervisorctl status "${program_name}" 2>/dev/null || true)"

    if printf '%s' "${status_output}" | awk '{print tolower($2)}' | grep -qx 'running'; then
        return 0
    fi

    echo "Healthcheck failed: ${program_name} is not running (status: ${status_output:-no output})"
    return 1
}

if [ "${container_mode}" = "http" ]; then
    php "${ROOT}/artisan" octane:status
elif [ "${container_mode}" = "horizon" ]; then
    php "${ROOT}/artisan" horizon:status
elif [ "${container_mode}" = "scheduler" ]; then
    check_supervisor_program "scheduler:scheduler_0"
elif [ "${container_mode}" = "reverb" ]; then
    check_supervisor_program "reverb:reverb_0"
elif [ "${container_mode}" = "worker" ]; then
    check_supervisor_program "worker:worker_0"
elif [ "${container_mode}" = "nightwatch" ]; then
    check_supervisor_program "nightwatch:nightwatch_0"
else
    echo "Healthcheck failed: unknown CONTAINER_MODE '${container_mode}'."
    exit 1
fi
